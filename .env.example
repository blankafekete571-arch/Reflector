# Example environment variables for Reflektor
# Copy this file to ".env" and fill in your values, or set environment variables directly.

# Your OpenAI API key (required)
OPENAI_API_KEY=sk-REPLACE-WITH_YOUR_KEY
OPENAI_MODEL=gpt-4o

# Optional: model to use (defaults to gpt-4o)
# You can set to e.g. "gpt-4" if your account has access.
OPENAI_MODEL=gpt-4o

# Optional: control the response style / randomness
#TEMPERATURE=0.4

# Optional: Phoenix Arize tracing endpoint (defaults to http://127.0.0.1:6006/v1/traces)
# Uncomment to use a different Phoenix server
#PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces

# Notes:
# - Do NOT commit your real API key to version control.
# - On macOS / zsh you can load variables from this file with: export $(cat .env | xargs)  (use with caution)
# - Alternatively, install python-dotenv and the app can load the .env file programmatically.
# - Phoenix tracing is enabled by default in the LangChain version

